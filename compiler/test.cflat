using MyModule;

module MyModule {
    struct Player {
        name: string
        health: int
    }

    enum Direction {
        North,
        South,
        East,
        West
    }

    const MAX_HEALTH = 100;

    func takeDamage(p: Player, amount: int) -> abyss {
        p.health = p.health - amount;
    }

    func getHealth(p: Player) -> int {
        return p.health;
    }
}

